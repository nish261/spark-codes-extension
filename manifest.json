{
  "manifest_version": 3,
  "name": "TikTok Spark Codes",
  "version": "1.2",
  "description": "Fetch approved spark codes from your TikTok ad accounts",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": [
    "https://business-api.tiktok.com/*",
    "https://kinetiksoul.com/*",
    "https://ads.tiktok.com/*"
  ]
}
